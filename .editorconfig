# GJJ 项目编辑器配置
# 确保所有文件使用统一的编码和格式

root = true

# 通用设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

# Python 文件
[*.py]
indent_style = tab
indent_size = 4
max_line_length = 120

# JavaScript 文件
[*.js]
indent_style = tab
indent_size = 4

# TypeScript 文件
[*.ts]
indent_style = tab
indent_size = 4

# JSON 文件
[*.json]
indent_style = tab
indent_size = 2

# YAML 文件
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown 文件
[*.md]
trim_trailing_whitespace = false

# TSV 文件
[*.tsv]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = false

# HTML 文件
[*.html]
indent_style = tab
indent_size = 4

# CSS 文件
[*.css]
indent_style = tab
indent_size = 4

# Shell 脚本
[*.{sh,bash}]
charset = utf-8
end_of_line = lf

# Windows 批处理文件
[*.bat]
charset = utf-8
end_of_line = crlf

# 排除 vendor 目录
[{vendor,node_modules,__pycache__,.git}/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
