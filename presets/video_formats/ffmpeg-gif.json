{
    "main_pass":
    [
        "-n",
        "-filter_complex", [["[0:v] split [a][b]; [a] palettegen=reserve_transparent=on:transparency_color=${transparency_color} [p]; [b][p] paletteuse=dither=${dither}:alpha_threshold=${alpha_threshold}"]],
        "-loop", [["$loop"]]
    ],
    "extension": "gif",
    "extra_widgets": [
        ["dither", ["bayer", "heckbert", "floyd_steinberg", "sierra2", "sierra2_4a", "sierra3", "burkes", "atkinson", "none"], {"default": "sierra2_4a"}],
        ["alpha_threshold", "INT", {"default": 96, "min": 0, "max": 255, "step": 1}],
        ["transparency_color", "STRING", {"default": "ffffff"}],
        ["loop", "INT", {"default": 0, "min": 0, "max": 1000, "step": 1}]
    ]
}
