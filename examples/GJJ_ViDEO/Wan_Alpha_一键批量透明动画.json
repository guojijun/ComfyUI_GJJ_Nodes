me for S&R":"GJJ_MultifunctionCalculator","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.8"},"gjj_calculator_show_int_output":true,"gjj_calculator_show_formula_output":false},"widgets_values":["","x1 * x2+1",true,false,""],"color":"#1B252B","bgcolor":"#141B1F","boxcolor":"#3E4D54"},{"id":159,"type":"GJJ_TextInput","pos":[-848,569],"size":[448,278],"flags":{},"order":2,"mode":0,"inputs":[{"label":"《","localized_name":"《","name":"text_in","shape":7,"type":"STRING","link":null},{"label":"文本内容","localized_name":"文本内容","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"label":"》","localized_name":"》","name":"》","type":"STRING","links":null}],"properties":{"gjj_text_input_width":448,"Node name for S&R":"GJJ_TextInput","ue_properties":{"widget_ue_connectable":{"text":true},"version":"7.8","input_ue_unconnectable":{}},"gjj_text_input_saved_text":"## [🌏 模型下载](https://pan.quark.cn/s/6ec846f1f58d)\nComfyUI/\n├── 📁 diffusion_models\n│   └── wan2.1_t2v_14B_fp16.safetensors\n├── 📁 loras\n│   ├── epoch-13-1500_changed.safetensors\n│   └── lightx2v_T2V_14B_cfg_step_distill_v2_lora_rank64_bf16.safetensors\n├── 📁 text_encoders\n│   └── umt5_xxl_fp8_e4m3fn_scaled.safetensors\n├── 📁 vae\n│   ├── wan_alpha_2.1_vae_alpha_channel.safetensors.safetensors\n│   └── wan_alpha_2.1_vae_rgb_channel.safetensors.safetensors","gjj_text_input_mode":"preview"},"widgets_values":["","## [🌏 模型下载](https://pan.quark.cn/s/6ec846f1f58d)\nComfyUI/\n├── 📁 diffusion_models\n│   └── wan2.1_t2v_14B_fp16.safetensors\n├── 📁 loras\n│   ├── epoch-13-1500_changed.safetensors\n│   └── lightx2v_T2V_14B_cfg_step_distill_v2_lora_rank64_bf16.safetensors\n├── 📁 text_encoders\n│   └── umt5_xxl_fp8_e4m3fn_scaled.safetensors\n├── 📁 vae\n│   ├── wan_alpha_2.1_vae_alpha_channel.safetensors.safetensors\n│   └── wan_alpha_2.1_vae_rgb_channel.safetensors.safetensors","## [🌏 模型下载](https://pan.quark.cn/s/6ec846f1f58d)\nComfyUI/\n├── 📁 diffusion_models\n│   └── wan2.1_t2v_14B_fp16.safetensors\n├── 📁 loras\n│   ├── epoch-13-1500_changed.safetensors\n│   └── lightx2v_T2V_14B_cfg_step_distill_v2_lora_rank64_bf16.safetensors\n├── 📁 text_encoders\n│   └── umt5_xxl_fp8_e4m3fn_scaled.safetensors\n├── 📁 vae\n│   ├── wan_alpha_2.1_vae_alpha_channel.safetensors.safetensors\n│   └── wan_alpha_2.1_vae_rgb_channel.safetensors.safetensors"],"color":"#1B252B","bgcolor":"#141B1F","boxcolor":"#3E4D54"},{"id":160,"type":"GJJ_TextRandomLine","pos":[-152,68],"size":[400,316],"flags":{},"order":3,"mode":0,"inputs":[{"label":"固定前缀","localized_name":"固定前缀","name":"fixed_prefix","type":"STRING","widget":{"name":"fixed_prefix"},"link":null},{"label":"文本列表","localized_name":"文本列表","name":"texts","type":"STRING","widget":{"name":"texts"},"link":null},{"label":"序号值","localized_name":"序号值","name":"seed","type":"INT","widget":{"name":"seed"},"link":null},{"label":"过滤空行","localized_name":"过滤空行","name":"strip_empty","type":"BOOLEAN","widget":{"name":"strip_empty"},"link":null}],"outputs":[{"localized_name":"合并正面提示词结果","name":"合并正面提示词结果","type":"STRING","links":[314]},{"localized_name":"文本总行数量","name":"文本总行数量","type":"INT","links":null},{"localized_name":"随机文本","name":"随机文本","type":"STRING","links":null}],"properties":{"Node name for S&R":"GJJ_TextRandomLine","gjj_text_random_line_auto":false},"widgets_values":["","透明背景","一只猫咪从纸箱里探出脑袋，歪头看向镜头，尾巴轻轻摆动\n旋转的星空，星云缓慢流动，中心透出柔和的光晕\n雨滴落在水面，泛起一圈圈涟漪，逐渐扩散消失\n打字机键盘上的手指快速敲击，屏幕上逐字跳出文字\n跳动的火焰，火苗忽明忽暗，随风微微摇曳\n卡通小人在原地跑步，背景不断向后移动，营造前进感\n飘落的樱花花瓣，在空中打着旋儿缓缓下落\n咖啡杯里的液体旋转，奶泡慢慢拉出心形拉花\n时钟指针一圈圈转动，背景颜色随时间变化\n气球被针扎破，瞬间泄气收缩，发出 “噗” 的音效（视觉化表现）\n海浪拍打着沙滩，泡沫退去又涌上，循环往复\n键盘上的按键依次亮起，从左到右形成流动光效\n猫咪追逐激光红点，在屏幕上左右跳跃\n蜡烛被点燃，火苗摇曳，蜡油顺着烛台慢慢流下\n齿轮组缓慢转动，大小齿轮相互咬合，精准同步\n雪花在空中飘落，逐渐覆盖地面，背景逐渐变白\n画笔在画布上快速涂抹，颜色从无到有，画出简单图案\n心跳波形在屏幕上起伏，节奏稳定，忽快忽慢\n泡泡从底部升起，逐渐变大，碰到顶部破裂消失\n汽车在公路上行驶，窗外的树木快速向后掠过\n猫咪踩奶，爪子一伸一缩，表情惬意\n霓虹灯招牌文字逐个亮起，又逐个熄灭，循环闪烁\n纸飞机在空中划出弧线，最后轻轻落地\n水滴从叶片滑落，滴入下方水洼，溅起小水花\n音乐播放器的均衡器随着节奏跳动，高低起伏\n小人儿在跑步机上跑步，脚下的履带不断转动\n云朵在天空中缓慢移动，形状不断变化\n灯泡被拧亮，灯丝逐渐变亮，发出温暖的光\n折纸鹤的过程，一张方纸慢慢折叠成纸鹤形状\n风吹动窗帘，布料轻轻摆动，阳光透过缝隙洒下\n猫咪舔爪子，舌头快速舔过，爪子来回蹭脸\n进度条从 0% 缓慢加载到 100%，数字同步变化\n纸船在小溪里漂流，绕过石头，随波逐流\n星星在夜空中闪烁，忽明忽暗，连成星座轮廓\n画笔蘸取颜料，在调色盘上混合，调出渐变色彩\n门被推开，光线从缝隙中照入，灰尘在光中飞舞\n狗狗摇着尾巴，围着主人转圈，兴奋地蹦跳\n齿轮钟表的指针转动，钟摆左右摇摆，发出滴答声（视觉化）\n雨滴打在窗户上，顺着玻璃流下，划出一道道水痕\n打字机打出错误文字，被划掉，重新输入正确内容\n蝴蝶破茧而出，翅膀慢慢展开，第一次扇动\n篝火晚会的火焰，人们围着篝火跳舞，影子在地上晃动\n风吹动风铃，铃铛相互碰撞，光影随声音闪烁\n咖啡被倒入杯中，液体旋转，表面泛起泡沫\n猫咪玩毛线球，爪子拨弄着线团，线越滚越长\n时钟的秒针快速转动，时间加速流逝，背景逐渐变暗\n肥皂泡在空中飘飞，反射出彩虹光芒，轻轻破裂\n画笔在黑板上写字，粉笔灰飘落，字迹逐渐清晰\n海浪冲击礁石，浪花飞溅，泡沫顺着礁石流下\n键盘上的回车键被按下，屏幕上的文字提交，弹出成功提示\n猫咪打哈欠，嘴巴张得很大，眼睛眯成一条缝\n旋转木马缓慢转动，灯光闪烁，音乐盒旋律可视化\n纸飞机被扔出，在空中滑翔，被风吹得上下起伏\n水滴从水龙头滴落，一滴接一滴，节奏均匀\n音乐播放时的声波可视化，线条随节奏扭曲变形\n小人儿跳绳，绳子上下翻飞，双脚轻快跳跃\n月亮从云层后露出，逐渐变圆，又慢慢被遮住\n灯泡被拧灭，灯丝逐渐变暗，房间陷入黑暗\n折纸星星的过程，纸条被折叠成五角星形状\n风吹动树叶，叶子沙沙作响，树枝轻轻晃动\n猫咪追着自己的尾巴转圈，越转越快，最后停下\n加载动画的环形图标，一圈圈旋转，颜色不断变化\n纸船被风吹翻，倒扣在水面上，慢慢随波漂走\n流星划过夜空，拖着长长的尾巴，消失在天际\n画笔在纸上画圈，线条越来越粗，颜色逐渐加深\n窗户被推开，风把窗帘吹起，外面的阳光照进来\n狗狗接住飞盘，跳起来咬住，落地后摇着尾巴跑回来\n沙漏里的沙子从上方流到下方，逐渐堆积成锥形\n雨滴打在伞面上，顺着伞骨流下，形成水帘\n打字机换行，纸张向上移动，继续打下一行文字\n毛毛虫慢慢爬行，身体一拱一拱，向前移动\n篝火被点燃，火焰从无到有，越烧越旺\n风吹动风车，叶片快速转动，颜色随转动变化\n牛奶被倒入咖啡中，两种液体混合，形成渐变效果\n猫咪趴在键盘上，爪子不小心按下按键，屏幕上出现乱码\n进度条加载失败，重新开始，反复循环\n纸飞机撞到墙上，弹回来，掉在地上\n雪花落在树枝上，越积越多，树枝慢慢被压弯\n画笔在画布上画直线，从左到右，颜色逐渐过渡\n门被关上，光线被切断，房间陷入昏暗\n狗狗摇尾巴，尾巴越摇越快，整个身体都跟着晃动\n钟表的齿轮内部结构，齿轮相互咬合，带动指针转动\n雨滴打在荷叶上，水珠滚来滚去，最后滑落\n键盘上的空格键被长按，光标快速向后移动\n猫咪蜷缩在阳光下睡觉，肚子随着呼吸起伏\n霓虹灯广告牌上的文字循环滚动，不断重复\n纸船被浪打翻，又翻回来，继续漂流\n星星被云朵遮住，又露出来，循环往复\n画笔蘸取清水，在颜料上晕染，颜色慢慢扩散\n窗帘被风吹得鼓起，又落下，来回摆动\n猫咪跳上窗台，爪子扒着玻璃，看向窗外\n加载动画的点状图标，点依次亮起，形成流动效果\n纸飞机被风吹得打转，最后掉落在地上\n雪花落在帽子上，堆积成小雪山，又被风吹走\n画笔在黑板上画星星，画了擦，擦了又画\n门被反复开关，光线忽明忽暗，形成闪烁效果\n狗狗追着球跑，球滚远，狗狗快速追上，用嘴叼回来\n沙漏被倒过来，沙子重新从上方流到下方\n雨滴打在水坑里，溅起一圈圈涟漪，重叠在一起\n打字机打出 “Hello”，然后被全部划掉，重新输入 “World”",100,"",true,"",""],"color":"#1B252B","bgcolor":"#141B1F","boxcolor":"#3E4D54"}],"links":[[269,138,2,126,1,"VAE"],[270,138,1,124,1,"VAE"],[271,138,3,139,0,"CLIP"],[284,124,0,143,0,"IMAGE"],[285,126,0,143,1,"IMAGE"],[289,138,0,149,0,"MODEL"],[290,139,0,149,1,"CONDITIONING"],[291,139,1,149,2,"CONDITIONING"],[292,136,0,149,3,"LATENT"],[293,149,0,126,0,"LATENT"],[294,149,0,124,0,"LATENT"],[297,144,