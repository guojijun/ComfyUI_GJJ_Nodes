点结果","name":"浮点结果","type":"FLOAT","links":null},{"label":"整数结果","localized_name":"整数结果","name":"整数结果","type":"INT","links":[578]}],"properties":{"Node name for S&R":"GJJ_MultifunctionCalculator","gjj_calculator_show_int_output":true,"gjj_calculator_show_formula_output":false},"widgets_values":["","x1/2",true,false,""],"color":"#1B252B","bgcolor":"#141B1F","boxcolor":"#3E4D54"},{"id":279,"type":"GJJ_MultifunctionCalculator","pos":[458,1473],"size":[225,110],"flags":{},"order":11,"mode":0,"inputs":[{"label":"x1","localized_name":"x1","name":"value_01","shape":7,"type":"*","link":573},{"label":"计算公式","localized_name":"计算公式","name":"formula","type":"STRING","widget":{"name":"formula"},"link":null},{"label":"x2","localized_name":"x2","name":"value_02","type":"*","link":null}],"outputs":[{"label":"浮点结果","localized_name":"浮点结果","name":"浮点结果","type":"FLOAT","links":null},{"label":"整数结果","localized_name":"整数结果","name":"整数结果","type":"INT","links":[577]}],"properties":{"Node name for S&R":"GJJ_MultifunctionCalculator","gjj_calculator_show_int_output":true,"gjj_calculator_show_formula_output":false},"widgets_values":["","x1/2",true,false,""],"color":"#1B252B","bgcolor":"#141B1F","boxcolor":"#3E4D54"},{"id":281,"type":"GJJ_CLIPPromptEncodePanel","pos":[313,718],"size":[384,256],"flags":{},"order":12,"mode":0,"inputs":[{"label":"CLIP 编码器","localized_name":"CLIP 编码器","name":"clip","type":"CLIP","link":599},{"label":"正面提示词","localized_name":"正面提示词","name":"positive_text","type":"STRING","widget":{"name":"positive_text"},"link":null},{"label":"负面提示词","localized_name":"负面提示词","name":"negative_text","type":"STRING","widget":{"name":"negative_text"},"link":null},{"label":"条件零化","localized_name":"条件零化","name":"zero_conditioning","type":"BOOLEAN","widget":{"name":"zero_conditioning"},"link":null},{"label":"翻译设备","localized_name":"翻译设备","name":"translation_device","type":"COMBO","widget":{"name":"translation_device"},"link":null},{"label":"翻译后卸载","localized_name":"翻译后卸载","name":"translation_unload_after_use","type":"BOOLEAN","widget":{"name":"translation_unload_after_use"},"link":null}],"outputs":[{"localized_name":"正面条件","name":"正面条件","type":"CONDITIONING","links":[580,581]},{"localized_name":"负面条件","name":"负面条件","type":"CONDITIONING","links":[582,583]}],"properties":{"Node name for S&R":"GJJ_CLIPPromptEncodePanel","gjj_clip_prompt_encode_panel_values":{"positive_text":"1. **镜头构图**：采用经典的中景镜头（Medium Shot），构图遵循三分法，将卡通狗置于画面左侧，卡通猫置于右侧，背景为虚化的温馨室内客厅，营造出亲密且私密的对话空间。\n\n2. **视频氛围**：整体色调采用柔和的暖黄色调，光线来自画面左后方的模拟夕阳余晖，投射出长长的金色轮廓光。色彩风格偏向吉卜力工作室的清新手绘质感，氛围略带一丝淡淡的忧伤与温情，背景音乐舒缓而略带 melancholic（感伤）。\n\n3. **动作描述**：\n   - 0-3 秒：一只金毛卡通狗正襟危坐，眼神关切地看着对面的猫，耳朵微微前倾，尾巴在身后轻轻摇摆。\n   - 3-5 秒：狗向前倾身，伸出爪子做出询问的手势，嘴巴张开，神情真诚。\n   - 5-8 秒：一只橘白相间的卡通猫瘫坐在地上，头顶有一团代表烦恼的黑色小云朵飘动，它低头看着自己的爪子，肩膀轻微耷拉，表现出明显的低落情绪。\n   - 8-10 秒：猫缓缓抬起头，眼神回避，嘴角向下撇，发出一声叹息。\n\n4. **运镜设计**：镜头起始为固定机位，在狗说话时镜头极其缓慢地向前推进（Dolly In）10%，聚焦于狗关切的面部表情；当猫开始回应并表现出难过时，镜头瞬间拉远（Pull Out）至中全景，并略微向下倾斜（Tilt Down），以强调猫的低落姿态和周围环境的空旷感。\n\n5. **配音与音频**：\n   - **环境音**：背景中有轻微的窗外鸟鸣声，以及远处模糊的时钟滴答声，音量极低，不干扰对话。\n   - **音乐**：钢琴独奏，旋律简单忧伤，节奏缓慢。\n   - **主角对话**：\n     - 狗（使用标准的重庆话，语气温暖、充满关切）：“你好嘛？”\n     - 猫（使用标准的重庆话，语速缓慢，带有一丝鼻音和撒娇般的委屈感）：“关你锤子事~\"","negative_text":"blurry, oversaturated, pixelated, low resolution, grainy, distorted, noise, compression artifacts, jpeg artifacts, glitches, watermark, text, logo, signature, copyright, subtitles, distorted sound, saturated sound, loud,字幕,中文字幕","zero_conditioning":false,"translation_device":"auto","translation_unload_after_use":false},"gjj_clip_prompt_value_positive_text":"1. **镜头构图**：采用经典的中景镜头（Medium Shot），构图遵循三分法，将卡通狗置于画面左侧，卡通猫置于右侧，背景为虚化的温馨室内客厅，营造出亲密且私密的对话空间。\n\n2. **视频氛围**：整体色调采用柔和的暖黄色调，光线来自画面左后方的模拟夕阳余晖，投射出长长的金色轮廓光。色彩风格偏向吉卜力工作室的清新手绘质感，氛围略带一丝淡淡的忧伤与温情，背景音乐舒缓而略带 melancholic（感伤）。\n\n3. **动作描述**：\n   - 0-3 秒：一只金毛卡通狗正襟危坐，眼神关切地看着对面的猫，耳朵微微前倾，尾巴在身后轻轻摇摆。\n   - 3-5 秒：狗向前倾身，伸出爪子做出询问的手势，嘴巴张开，神情真诚。\n   - 5-8 秒：一只橘白相间的卡通猫瘫坐在地上，头顶有一团代表烦恼的黑色小云朵飘动，它低头看着自己的爪子，肩膀轻微耷拉，表现出明显的低落情绪。\n   - 8-10 秒：猫缓缓抬起头，眼神回避，嘴角向下撇，发出一声叹息。\n\n4. **运镜设计**：