es":{"Node name for S&R":"GJJ_MultifunctionCalculator","gjj_calculator_show_int_output":false,"gjj_calculator_show_formula_output":false},"widgets_values":["int(x1)",false,false,"",null,""],"color":"#1B252B","bgcolor":"#141B1F","boxcolor":"#3E4D54"},{"id":92,"type":"GJJ_CLIPPromptEncodePanel","pos":[518,220],"size":[384,256],"flags":{},"order":8,"mode":0,"inputs":[{"label":"CLIP 编码器","localized_name":"CLIP 编码器","name":"clip","type":"CLIP","link":174},{"label":"正向提示词","localized_name":"正向提示词","name":"positive_prompt_input","shape":7,"type":"STRING","link":null},{"label":"负面提示词","localized_name":"负面提示词","name":"negative_text","type":"STRING","widget":{"name":"negative_text"},"link":null},{"label":"条件零化","localized_name":"条件零化","name":"zero_conditioning","type":"BOOLEAN","widget":{"name":"zero_conditioning"},"link":null},{"label":"翻译设备","localized_name":"翻译设备","name":"translation_device","type":"COMBO","widget":{"name":"translation_device"},"link":null},{"label":"翻译后卸载","localized_name":"翻译后卸载","name":"translation_unload_after_use","type":"BOOLEAN","widget":{"name":"translation_unload_after_use"},"link":null}],"outputs":[{"localized_name":"正面条件","name":"正面条件","type":"CONDITIONING","links":[158,227]},{"localized_name":"负面条件","name":"负面条件","type":"CONDITIONING","links":[160,228]}],"properties":{"Node name for S&R":"GJJ_CLIPPromptEncodePanel","gjj_clip_prompt_encode_panel_values":{"positive_text":"【镜头构图】\n中景固定镜头，水平视角，采用经典的“双人平行构图”。两人并排趴在沙滩上，画面中心聚焦于两人的上半身和手中的鸡尾酒。背景为横向延伸的蔚蓝大海与天空，利用浅景深虚化远处的海浪，突出前景人物。\n\n【视频氛围】\n画面光线为强烈的正午阳光，色调明快温暖，带有高饱和度的夏日度假感。整体氛围轻松、惬意、慵懒，充满海边的清凉气息与青春的活力。\n\n【动作描述】\n0-2秒：\n镜头聚焦于左侧女生。她银发披肩，戴着猫耳遮阳帽和墨镜，身穿黑色比基尼。她右手端着装有橙红色分层鸡尾酒的高脚杯，正轻轻将吸管送入口中啜饮，随后微微侧头，对着右侧的男生开口说话，神态轻松。\n\n2-12秒：\n镜头平滑切至右侧男生。他赤裸上身，皮肤健康古铜，戴着鸭舌帽和墨镜。他左手拿着装有黄色冰镇饮料的杯子，正用吸管吸饮。听到女生说话后，他停下动作，侧过脸看着女生，嘴唇微动进行回应，表情自然且带有笑意，保持着闲聊的状态。\n\n【运镜与切换】\n前2秒保持静止中景，捕捉女生喝饮料和说话的特写神态；第2秒处平滑地进行左右横移或硬切（Hard Cut），第2-12秒固定机位捕捉男生的反应和对话互动，镜头稳定不动，强调两人的交流感。","negative_text":"blurry, oversaturated, pixelated, low resolution, grainy